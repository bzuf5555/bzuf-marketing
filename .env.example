# Telegram Bot Token (BotFather dan olinadi)
BOT_TOKEN=your_bot_token_here

# Google Gemini API Key (aistudio.google.com dan BEPUL olinadi)
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Atlas URI (mongodb.com/atlas — bepul M0 cluster)
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bzuf_marketing

# Render.com avtomatik to'ldiradi (qo'lda to'ldirmang)
# RENDER_EXTERNAL_URL=your-app.onrender.com

# Local test uchun PORT (Render o'zi beradi)
PORT=8443
